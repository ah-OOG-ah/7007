20,"objectType":"Text","label":"Fetch\n\nROM is triplicated, so that three bytes can be\nfetched simultaneously. This is because\ninstructions are variable-width, up to 3 bytes\nwide, and I don't want to handle manually\npulsing out three at a time via shift buffers\nor something similar.","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":["Fetch\n\nROM is triplicated, so that three bytes can be\nfetched simultaneously. This is because\ninstructions are variable-width, up to 3 bytes\nwide, and I don't want to handle manually\npulsing out three at a time via shift buffers\nor something similar.",14]}},{"x":380,"y":130,"objectType":"Text","label":"Decode Blocks","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":["Decode Blocks",14]}},{"x":590,"y":70,"objectType":"Text","label":"Decode: NOP","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":["Decode: NOP",14]}},{"x":450,"y":370,"objectType":"Text","label":"Decode: MOV R, value\n00 RRR 110 DDDDDDDD\nCopy a value into a specified register.","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":["Decode: MOV R, value\n00 RRR 110 DDDDDDDD\nCopy a value into a specified register.",14]}},{"x":510,"y":-50,"objectType":"Text","label":"Each instruction returns the number of bytes it took.\nThis lets the IP jump forwards appropriately.\n\nHLT gives zero, so the CPU does nothing forever.","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":["Each instruction returns the number of bytes it took.\nThis lets the IP jump forwards appropriately.\n\nHLT gives zero, so the CPU does nothing forever.",14]}},{"x":1390,"y":10,"objectType":"Text","label":"Accumulator","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":["Accumulator",14]}},{"x":1390,"y":70,"objectType":"Text","label":"B","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":["B",14]}},{"x":1390,"y":130,"objectType":"Text","label":"C","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":["C",14]}},{"x":1390,"y":190,"objectType":"Text","label":"D","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":["D",14]}},{"x":1390,"y":250,"objectType":"Text","label":"E","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":["E",14]}},{"x":1390,"y":310,"objectType":"Text","label":"H","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":["H",14]}},{"x":1390,"y":370,"objectType":"Text","label":"L","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":["L",14]}},{"x":1390,"y":-10,"objectType":"Text","label":"Registers","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":["Registers",14]}},{"x":1260,"y":450,"objectType":"Text","label":"Write to RAM (TODO)","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":["Write to RAM (TODO)",14]}},{"x":560,"y":560,"objectType":"Text","label":"Decode: MOV R1, R2\n01 DDD SSS\nCopy a register into a specified other \nregister.","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":["Decode: MOV R1, R2\n01 DDD SSS\nCopy a register into a specified other \nregister.",14]}},{"x":190,"y":810,"objectType":"Text","label":"Decode: ADD value\nAdd the value to the accumulator","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":["Decode: ADD value\nAdd the value to the accumulator",14]}},{"x":2060,"y":460,"objectType":"Text","label":"Carry Bit","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":["Carry Bit",14]}},{"x":2060,"y":520,"objectType":"Text","label":"Zero Bit","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":["Zero Bit",14]}},{"x":2060,"y":580,"objectType":"Text","label":"Sign Bit","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":["Sign Bit",14]}},{"x":2060,"y":640,"objectType":"Text","label":"Parity Bit","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":["Parity Bit",14]}},{"x":1930,"y":420,"objectType":"Text","label":"Flag Data","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":["Flag Data",14]}},{"x":710,"y":360,"objectType":"Text","label":"Next Opcode offset line","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":["Next Opcode offset line",14]}},{"x":1050,"y":-20,"objectType":"Text","label":"Register Buffer\n(Data, Address, WE)","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":["Register Buffer\n(Data, Address, WE)",14]}},{"x":1000,"y":290,"objectType":"Text","label":"Flag Buffer \nData low, WE high","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":["Flag Buffer \nData low, WE high",14]}},{"x":200,"y":1020,"objectType":"Text","label":"Decode: ADD register\nAdd a register to the accumulator.","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":["Decode: ADD register\nAdd a register to the accumulator.",14]}},{"x":-370,"y":330,"objectType":"Text","label":"Clock cycle:\n1: Decode instruction + exec\n2: Write memory\n3: Bump IP","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":["Clock cycle:\n1: Decode instruction + exec\n2: Write memory\n3: Bump IP",14]}},{"x":-90,"y":-30,"objectType":"Text","label":"Next Instruction Offset","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":["Next Instruction Offset",14]}},{"x":-780,"y":40,"objectType":"Text","label":"Accumulator","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":["Accumulator",14]}},{"x":-630,"y":40,"objectType":"Text","label":"Register B","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":["Register B",14]}},{"x":-780,"y":210,"objectType":"Text","label":"Register C","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":["Register C",14]}},{"x":-630,"y":210,"objectType":"Text","label":"Register D","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":["Register D",14]}},{"x":-790,"y":360,"objectType":"Text","label":"Register D","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":["Register D",14]}},{"x":-780,"y":380,"objectType":"Text","label":"Register E","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":["Register E",14]}},{"x":-770,"y":550,"objectType":"Text","label":"Register H","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":["Register H",14]}},{"x":-620,"y":550,"objectType":"Text","label":"Register L","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":["Register L",14]}},{"x":-470,"y":550,"objectType":"Text","label":"Register M","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":["Register M",14]}},{"x":620,"y":230,"objectType":"Text","label":"Decode: HLT","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":["Decode: HLT",14]}},{"x":-810,"y":570,"objectType":"Text","label":"This is an attempt at an 8080-like processor. As such:\n- Register numbering is 8080, with 3 bits. B, C, D, E, H, L, M. 111 is unused.\n- While four flags are present, the implemented opcodes only use the carry.\n- The L register is used for indirect memory access. Due to CircuitVerse limitations, I only implemented 16 bytes of it.","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":["This is an attempt at an 8080-like processor. As such:\n- Register numbering is 8080, with 3 bits. B, C, D, E, H, L, M. 111 is unused.\n- While four flags are present, the implemented opcodes only use the carry.\n- The L register is used for indirect memory access. Due to CircuitVerse limitations, I only implemented 16 bytes of it.",14]}},{"x":170,"y":1310,"objectType":"Text","label":"Decode: SHL/SHR register\n0000 0111/0000 1111\nShift the accumulator by 1, left or right.\n\nUses the ROR/ROL opcodes, since I\ndon't need rotation.","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":["Decode: SHL/SHR register\n0000 0111/0000 1111\nShift the accumulator by 1, left or right.\n\nUses the ROR/ROL opcodes, since I\ndon't need rotation.",14]}}],"Rectangle":[{"x":2200,"y":-120,"objectType":"Rectangle","label":"RAM","direction":"RIGHT","labelDirection":"LEFT","propagationDelay":10,"customData":{"constructorParamaters":[76,71]}}],"restrictedCircuitElementsUsed":[],"nodes":[42,43,44,45,46,79,80,81,82,83,84,85,86,87,88,89,90,91,92,93,94,95,96,97,98,99,100,101,102,103,104,105,106,107,108,109,110,111,112,113,114,115,116,117,118,119,150,152,153,181,182,183,190,207,214,217,236,237,238,239,240,241,242,243,244,245,246,252,253,254,255,256,281,282,283,284,285,286,287,288,289,290,291,297,298,299,300